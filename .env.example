# Copy this file to `.env` (same directory as docker-compose.yml) and edit.
# Docker Compose loads `.env` automatically. Do NOT commit your real `.env`.
# Generate each secret with a fresh random — never reuse a value across fields:
#   openssl rand -hex 24   (user secrets)   |   openssl rand -hex 32   (PBKDF)

# --- MinIO root account (full admin) ---------------------------------------
# Bootstrap superuser, set from these env vars on every boot. Used by
# console-init to provision the console user; NOT what you log into the UI with
# day to day (use the console user below). Keep this password strong + private.
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change-me-to-a-long-random-password

# --- OpenMaxIO console session-encryption secrets --------------------------
# Encrypt the console's session JWTs. Two DISTINCT long randoms.
CONSOLE_PBKDF_PASSPHRASE=change-me-passphrase-32-bytes
CONSOLE_PBKDF_SALT=change-me-salt-32-bytes

# --- Console admin user (auto-provisioned by the console-init service) ------
# Dedicated non-root admin you log into the console (:9090) with. console-init
# creates/updates it on every `up` from these values, so this file is the source
# of truth — rotate the secret here, then re-run `up`.
CONSOLE_ACCESS_KEY=console
CONSOLE_SECRET_KEY=change-me-console-secret
